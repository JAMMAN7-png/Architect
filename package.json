{
  "name": "@jamman7/architect",
  "version": "0.1.0-pre.0",
  "description": "Idea-to-Blueprint generator. Opus-led pipeline that turns a human idea into a frozen Blueprint and a strict per-service docs tree.",
  "type": "module",
  "license": "MIT",
  "author": "JAMMAN AFRE <pishro@duck.com>",
  "homepage": "https://github.com/JAMMAN7-png/Architect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JAMMAN7-png/Architect.git"
  },
  "bugs": {
    "url": "https://github.com/JAMMAN7-png/Architect/issues"
  },
  "keywords": [
    "blueprint",
    "documentation",
    "generator",
    "cli",
    "ai",
    "claude",
    "agents",
    "microservices",
    "scaffolding"
  ],
  "bin": {
    "architect": "bin/architect"
  },
  "files": ["bin", "dist", "src/templates", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun scripts/build.ts",
    "build:bin": "bun scripts/build.ts --compile",
    "build:bin:linux-x64": "bun scripts/build.ts --compile --target=bun-linux-x64",
    "build:bin:linux-arm64": "bun scripts/build.ts --compile --target=bun-linux-arm64",
    "build:bin:darwin-x64": "bun scripts/build.ts --compile --target=bun-darwin-x64",
    "build:bin:darwin-arm64": "bun scripts/build.ts --compile --target=bun-darwin-arm64",
    "build:bin:windows-x64": "bun scripts/build.ts --compile --target=bun-windows-x64",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "openai": "^4.65.0",
    "@iarna/toml": "^2.2.5",
    "eta": "^3.5.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8",
    "p-limit": "^6.1.0",
    "yargs-parser": "^22.0.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
    "ora": "^8.1.1",
    "tiktoken": "^1.0.20",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "@types/diff": "^6.0.0",
    "@types/prompts": "^2.4.9",
    "@types/yargs-parser": "^21.0.3",
    "typescript": "^5.6.3"
  }
}
