# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ADMIN_CHAT_ID=replace-me

# Bot host
BOT_PUBLIC_URL=https://arch.example.com
BOT_PORT=3000
BOT_WEBHOOK_SECRET=

# LLM providers (set whichever you have keys for)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENCODE_ZEN_API_KEY=
OPENCODE_GO_API_KEY=

# Search providers
FIRECRAWL_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=

# Architect overrides (optional)
ARCHITECT_MODEL_STRATEGIC=anthropic/claude-opus-4-5
ARCHITECT_MODEL_EXECUTION=deepseek/deepseek-chat
ARCHITECT_MODEL_UI=anthropic/claude-opus-4-5
ARCHITECT_MODEL_FALLBACK=openrouter/auto
ARCHITECT_MODEL_ENSEMBLE=xai/grok-4,deepseek/deepseek-r1
ARCHITECT_SEARCH_PROVIDER=firecrawl

# Telegram custom emoji entities (optional; empty = static fallback)
# Populate with custom_emoji_id values from your Premium emoji set.
TG_CUSTOM_EMOJI_SUCCESS=
TG_CUSTOM_EMOJI_ERROR=
TG_CUSTOM_EMOJI_WARNING=
TG_CUSTOM_EMOJI_INFO=
TG_CUSTOM_EMOJI_PRIMARY=
TG_CUSTOM_EMOJI_DESTRUCTIVE=
TG_CUSTOM_EMOJI_EDIT=
TG_CUSTOM_EMOJI_CONTINUE=
TG_CUSTOM_EMOJI_MODAL_LOCK=
TG_CUSTOM_EMOJI_FLOW_LOCK=
TG_CUSTOM_EMOJI_LOADING=
